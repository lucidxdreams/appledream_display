rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // PUBLIC READ — Display frontend (no auth needed)
    // ─────────────────────────────────────────────

    // Legacy root-level collections (kept for backward compatibility)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{categorySlug}/items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────────
    // LOCATIONS — Scoped per-location data
    // Display reads publicly; admin writes require auth
    // ─────────────────────────────────────────────

    // Location categories
    match /locations/{locationId}/categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Location products
    match /locations/{locationId}/products/{categorySlug}/items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Location deals
    match /locations/{locationId}/deals/{dealId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Location settings (lastPushed etc.)
    match /locations/{locationId}/settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────────
    // AUTH-ONLY — Admin panel internals
    // ─────────────────────────────────────────────

    match /audit/{logId} {
      allow read, write: if request.auth != null;
    }

    // Any other collection: require auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
